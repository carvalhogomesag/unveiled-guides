<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | Unveiled Guides</title>
    <!-- MENSAGEM GLOBALIZADA -->
    <meta name="description" content="Expert historical and practical guides to the world's most iconic landmarks. Discover the stories behind the sights, avoid the traps, and make your trip unforgettable.">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700&family=Poppins:wght@700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,700&display=swap" rel="stylesheet">
    
    <!-- Our Stylesheet -->
    <link rel="stylesheet" href="/css/style.css">

    <!-- Favicon Links -->
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">

    <!-- Scripts -->
    <script async defer src="https://widget.getyourguide.com/dist/pa.umd.production.min.js" data-gyg-partner-id="PMW7G72"></script>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-YQ6WR6XMCC"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-YQ6WR6XMCC');
    </script>
</head>
<body>

    <!-- MENSAGEM GLOBALIZADA -->
    <div class="top-bar">
        Unveiling the history & secrets of iconic landmarks ✨
    </div>

    <header class="site-header">
        <a href="/" class="logo-link">
            <!-- SVG do Logo Náutico -->
            <svg class="site-logo" width="400" height="50" viewBox="0 0 400 50" fill="none" xmlns="http://www.w3.org/2000/svg">
                <title>Unveiled Guides Logo</title>
                <g class="logo-symbol">
                    <path d="M25 5V15M25 35V45M45 25H35M15 25H5M35.3553 14.6447L29.6985 20.3015M20.3015 29.6985L14.6447 35.3553M35.3553 35.3553L29.6985 29.6985M20.3015 20.3015L14.6447 14.6447" stroke="var(--dark-text)" stroke-width="3" stroke-linecap="round"/>
                    <circle cx="25" cy="25" r="15" fill="white" stroke="var(--dark-text)" stroke-width="3"/>
                    <circle cx="25" cy="25" r="5" fill="var(--primary-blue)"/>
                </g>
                <g class="logo-text">
                    <text x="55" y="32" font-family="Cinzel, serif" font-size="24" font-weight="700" fill="var(--dark-text)">Unveiled Guides</text>
                    <!-- MENSAGEM GLOBALIZADA -->
                    <text x="55" y="46" font-family="var(--sans-serif-font)" font-size="10" fill="#6b7280">Your essential guides to the world's greatest sights</text>
                </g>
            </svg>
        </a>

        <!-- Navegação de Desktop -->
        <nav class="main-nav">
            <ul>
                {% for item in navigation.items %}
                <li>
                    <a href="{{ item.url }}">{{ item.text }}</a>
                </li>
                {% endfor %}
            </ul>
        </nav>

        <!-- Botão Hambúrguer para Mobile -->
        <button class="mobile-nav-toggle" aria-controls="primary-navigation" aria-expanded="false">
            <span class="sr-only">Menu</span>
            <div class="hamburger-lines"></div>
        </button>
    </header>

    <!-- Menu Modal para Mobile -->
    <nav class="fullscreen-nav" id="primary-navigation" data-visible="false">
        <ul class="fullscreen-nav__list">
            {% for item in navigation.items %}
            <li class="fullscreen-nav__item">
                <a href="{{ item.url }}" class="fullscreen-nav__link">{{ item.text }}</a>
            </li>
            {% endfor %}
        </ul>
    </nav>

    {% if page.url == '/' %}
    <!-- MENSAGEM GLOBALIZADA -->
    <div class="hero-section">
        <h2>Unlock the Secrets of the World's Greatest Landmarks</h2>
        <p>We go beyond the typical tourist guides. Discover the hidden histories, avoid the common traps, and transform your visit from a simple photo-op into an unforgettable experience.</p>
    </div>
    {% endif %}

    <main>
        {{ content | safe }}
    </main>

    <footer>
        <p>© 2024 Unveiled Guides. All rights reserved. Your adventure starts here.</p>
    </footer>

    <script src="/js/mobile-nav.js" defer></script>
</body>
</html>