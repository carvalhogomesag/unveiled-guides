<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- SEO Meta Tags -->
    <title>{{ title }} | Unveiled Guides</title>
    <meta name="description" content="Expert historical and practical guides to Portugal's most iconic landmarks. Discover the stories behind the sights and make your trip unforgettable.">

    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,700&display=swap" rel="stylesheet">
    
    <!-- Our Stylesheet -->
    <link rel="stylesheet" href="/css/style.css">

    <!-- GetYourGuide Analytics -->
    <script async defer src="https://widget.getyourguide.com/dist/pa.umd.production.min.js" data-gyg-partner-id="PMW7G72"></script>
</head>
<body>
    <div class="top-bar">
        Your essential guides to Portugal's history & culture ✨
    </div>
    <header>
        <a href="/" class="logo-link">
    <svg class="site-logo" width="230" height="40" viewBox="0 0 230 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <title>Unveiled Guides Logo</title>
        <circle cx="20" cy="20" r="19" stroke="var(--dark-text)" stroke-width="2"/>
        <path d="M20 7L23 20L20 33L17 20L20 7Z" fill="var(--primary-blue)"/>
        <text x="20" y="25" font-family="var(--display-font)" font-size="12" font-weight="700" text-anchor="middle" fill="var(--dark-text)">UG</text>
        <text x="50" y="27" font-family="var(--display-font)" font-size="24" font-weight="700" fill="var(--dark-text)">Unveiled Guides</text>
    </svg>
</a>
        <nav>
            <a href="/">Home</a>
            {# Futuramente podemos adicionar mais links como /about/ ou /contact/ #}
        </nav>
    </header>

    <main>
        {{ content | safe }}
    </main>

    <footer>
        <p>© 2024 Unveiled Guides. All rights reserved. Your adventure starts here.</p>
    </footer>
</body>
</html>