<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | Unveiled Guides</title>
    <meta name="description" content="Expert historical and practical guides to Portugal's most iconic landmarks. Discover the stories behind the sights and make your trip unforgettable.">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700&family=Poppins:wght@700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,700&display=swap" rel="stylesheet">
    
    <!-- Our Stylesheet -->
    <link rel="stylesheet" href="/css/style.css">

    <!-- Favicon Links -->
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">

    <!-- Scripts -->
    <script async defer src="https://widget.getyourguide.com/dist/pa.umd.production.min.js" data-gyg-partner-id="PMW7G72"></script>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-YQ6WR6XMCC"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-YQ6WR6XMCC');
    </script>
</head>
<body>

    <header class="site-header">
        <a href="/" class="logo-link">
            <!-- SVG do Logo Náutico -->
            <svg class="site-logo" width="280" height="40" viewBox="0 0 280 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                <title>Unveiled Guides Logo</title>
                <g class="logo-symbol"><path d="M20 2V10M20 30V38M38 20H30M10 20H2M32.6274 7.37258L25.8594 14.1406M14.1406 25.8594L7.37258 32.6274M32.6274 32.6274L25.8594 25.8594M14.1406 14.1406L7.37258 7.37258" stroke="var(--dark-text)" stroke-width="2" stroke-linecap="round"/><circle cx="20" cy="20" r="12" fill="white" stroke="var(--dark-text)" stroke-width="2"/><circle cx="20" cy="20" r="4" fill="var(--primary-blue)"/></g>
                <g class="logo-text"><text x="45" y="27" font-family="Cinzel, serif" font-size="20" font-weight="700" fill="var(--dark-text)">Unveiled Guides</text></g>
            </svg>
        </a>

        <button class="mobile-nav-toggle" aria-controls="main-navigation" aria-expanded="false">
            <span class="sr-only">Menu</span>
            <svg class="icon-hamburger" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
            <svg class="icon-close" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>

        <nav class="main-nav-wrapper">
            <ul class="main-nav" id="main-navigation" data-visible="false">
                
                <!-- *** AQUI ESTÁ A ALTERAÇÃO CRUCIAL *** -->
                {% for item in navigation.items %}
                <li>
                    <a href="{{ item.url }}">{{ item.text }}</a>
                </li>
                {% endfor %}
                
            </ul>
        </nav>
    </header>

    {% if page.url == '/' %}
    <div class="hero-section">
        <h2>Discover the Stories Behind the Sights</h2>
        <p>We provide in-depth guides to help you understand the rich history of Portugal's landmarks, transforming your visit from a simple photo-op into an unforgettable experience.</p>
    </div>
    {% endif %}

    <main>
        {{ content | safe }}
    </main>

    <footer>
        <p>© 2024 Unveiled Guides. All rights reserved. Your adventure starts here.</p>
    </footer>

    <script src="/js/mobile-nav.js" defer></script>
</body>
</html>