<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-YQ6WR6XMCC"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-YQ6WR6XMCC');
</script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | Unveiled Guides</title>
    <meta name="description" content="Expert historical and practical guides to Portugal's most iconic landmarks. Discover the stories behind the sights and make your trip unforgettable.">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,700&display=swap" rel="stylesheet">
    
    <!-- Our Stylesheet -->
    <link rel="stylesheet" href="/css/style.css">

    <!-- Favicon Links (Gerados pelo RealFaviconGenerator) -->
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#005a9c">
    <meta name="msapplication-TileColor" content="#005a9c">
    <meta name="theme-color" content="#ffffff">

    <!-- GetYourGuide Analytics -->
    <script async defer src="https://widget.getyourguide.com/dist/pa.umd.production.min.js" data-gyg-partner-id="PMW7G72"></script>
</head>
<body>
    <div class="top-bar">
        Your essential guides to Portugal's history & culture ✨
    </div>

    <div class="header-block">
        <header>
            <a href="/" class="logo-link">
                <svg class="site-logo" width="230" height="40" viewBox="0 0 230 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <title>Unveiled Guides Logo</title>
                    <circle cx="20" cy="20" r="19" stroke="var(--dark-text)" stroke-width="2"/>
                    <path d="M20 7L23 20L20 33L17 20L20 7Z" fill="var(--primary-blue)"/>
                    <text x="20" y="25" font-family="var(--display-font)" font-size="12" font-weight="700" text-anchor="middle" fill="var(--dark-text)">UG</text>
                    <text x="50" y="27" font-family="var(--display-font)" font-size="24" font-weight="700" fill="var(--dark-text)">Unveiled Guides</text>
                </svg>
            </a>
            <nav>
                <a href="/">Home</a>
            </nav>
        </header>

        {% if page.url == '/' %}
        <div class="hero-section">
            <h2>Discover the Stories Behind the Sights</h2>
            <p>We provide in-depth guides to help you understand the rich history of Portugal's landmarks, transforming your visit from a simple photo-op into an unforgettable experience.</p>
        </div>
        {% endif %}
    </div>

    <main>
        {{ content | safe }}
    </main>

    <footer>
        <p>© 2024 Unveiled Guides. All rights reserved. Your adventure starts here.</p>
    </footer>

    <!-- Nosso script de pesquisa (se aplicável no futuro) -->
    <!-- <script src="/js/search.js" defer></script> -->
</body>
</html>