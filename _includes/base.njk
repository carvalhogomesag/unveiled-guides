<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | Unveiled Guides</title>
    <meta name="description" content="Expert historical and practical guides to Portugal's most iconic landmarks. Discover the stories behind the sights and make your trip unforgettable.">

    <!-- Google Fonts (Incluindo a nova fonte Cinzel) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700&family=Poppins:wght@700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,700&display=swap" rel="stylesheet">
    
    <!-- Our Stylesheet -->
    <link rel="stylesheet" href="/css/style.css">

    <!-- Favicon Links (Use o código gerado pelo RealFaviconGenerator para o novo favicon) -->
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#005a9c">
    <meta name="msapplication-TileColor" content="#005a9c">
    <meta name="theme-color" content="#ffffff">

    <!-- GetYourGuide Analytics -->
    <script async defer src="https://widget.getyourguide.com/dist/pa.umd.production.min.js" data-gyg-partner-id="PMW7G72"></script>

    <!-- Google tag (gtag.js) - Lembre-se de colocar o seu ID real aqui -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>
</head>
<body class="body-background">

    <header class="site-header">
        <div class="top-bar">
            <a href="/" class="logo-link">
                <!-- NOSSO NOVO LOGO NÁUTICO -->
                <svg class="site-logo" width="400" height="50" viewBox="0 0 400 50" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <title>Unveiled Guides Logo</title>
                    <g class="logo-symbol">
                        <path d="M25 5V15M25 35V45M45 25H35M15 25H5M35.3553 14.6447L29.6985 20.3015M20.3015 29.6985L14.6447 35.3553M35.3553 35.3553L29.6985 29.6985M20.3015 20.3015L14.6447 14.6447" stroke="var(--dark-text)" stroke-width="3" stroke-linecap="round"/>
                        <circle cx="25" cy="25" r="15" fill="white" stroke="var(--dark-text)" stroke-width="3"/>
                        <circle cx="25" cy="25" r="5" fill="var(--primary-blue)"/>
                    </g>
                    <g class="logo-text">
                        <text x="55" y="32" font-family="Cinzel, serif" font-size="24" font-weight="700" fill="var(--dark-text)">Unveiled Guides</text>
                        <text x="55" y="46" font-family="var(--sans-serif-font)" font-size="10" fill="#6b7280">Your essential guides to Portugal's history & culture</text>
                    </g>
                </svg>
            </a>
            <!-- Futuramente: ícones sociais e busca à direita -->
        </div>

        <nav class="main-nav">
            <ul>
                {% for tag in collections.navTags %}
                <li>
                    <a href="/tags/{{ tag | slugify }}/">{{ tag }}</a>
                </li>
                {% endfor %}
            </ul>
        </nav>
    </header>

    {% if page.url == '/' %}
    <div class="hero-section">
        <h2>Discover the Stories Behind the Sights</h2>
        <p>We provide in-depth guides to help you understand the rich history of Portugal's landmarks, transforming your visit from a simple photo-op into an unforgettable experience.</p>
    </div>
    {% endif %}

    <main>
        {{ content | safe }}
    </main>

    <footer>
        <p>© 2024 Unveiled Guides. All rights reserved. Your adventure starts here.</p>
    </footer>
</body>
</html>